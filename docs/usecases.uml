@startuml
left to right direction
skinparam packageStyle rectangle

actor "Usuário Não Autenticado" as Guest
actor "Usuário Autenticado" as User
actor "Administrador" as Admin

rectangle MovaFin {
  usecase "UC-01: Gerenciar Autenticação" as UC01
  usecase "UC-02: Gerenciar Contas" as UC02
  usecase "UC-03: Gerenciar Transações" as UC03
  usecase "UC-04: Gerenciar Categorias" as UC04
  usecase "UC-05: Gerenciar Metas" as UC05
  usecase "UC-06: Consultar Dashboard" as UC06
  usecase "UC-07: Acessar Painel Administrativo" as UC07
}

Guest --> UC01
User --> UC01
User --> UC02
User --> UC03
User --> UC04
User --> UC05
User --> UC06

Admin --|> User
Admin --> UC07

@enduml
