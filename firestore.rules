rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model using hierarchical path-based multi-tenancy.
     * All financial data (Accounts, Transactions, etc.) is nested under /users/{userId} to ensure 
     * that query access patterns are naturally scoped to the authenticated user.
     *
     * DATA STRUCTURE:
     * - /users/{userId}: The root user profile.
     * - /users/{userId}/account_types: User-customizable account classifications.
     * - /users/{userId}/accounts: Financial accounts owned by the user.
     * - /users/{userId}/transaction_categories: User-customizable transaction classifications.
     * - /users/{userId}/accounts/{accountId}/transactions: Financial movements within an account.
     * - /users/{userId}/accounts/{accountId}/transactions/{transactionId}/attachments: Files linked to transactions.
     * - /roles_admin/{userId}: A system-level collection for administrative privileges.
     *
     * KEY SECURITY DECISIONS:
     * - DENORMALIZATION FOR AUTHORIZATION: Every document includes a `userId` field to allow for 
     *   Authorization Independence. This avoids expensive `get()` calls to parent documents.
     * - RELATIONAL INTEGRITY: Rules enforce that internal `userId` and parent-link fields (like `accountId`) 
     *   match the document's path during creation and remain immutable.
     * - PROTOTYPING FLEXIBILITY: Schema shapes (types, optional fields) are not validated to allow 
     *   rapid frontend iteration, while authorization remains strictly locked down.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profile documents. Controls access to the root of the user's data tree.
     * @path /users/{userId}
     * @allow Authenticated user with matching UID (get, list, create, update).
     * @deny Any user attempting to access or modify a profile that is not their own.
     * @principle Enforces self-creation and strict ownership for the root user entity.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false; // User accounts are typically deactivated, not deleted via client.

      /**
       * @description Rules for user-defined account types (e.g., 'Checking', 'Savings').
       * @path /users/{userId}/account_types/{accountTypeId}
       * @allow Owner of the parent userId path (all operations).
       * @deny Non-owners or unauthenticated users.
       * @principle Path-based multi-tenancy combined with internal userId validation.
       */
      match /account_types/{accountTypeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for financial accounts belonging to a user.
       * @path /users/{userId}/accounts/{accountId}
       * @allow Owner of the parent userId path (all operations).
       * @deny Cross-user access or unauthenticated access.
       * @principle Validates that the internal ownership field matches the path multi-tenancy.
       */
      match /accounts/{accountId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for transactions nested under a specific account.
         * @path /users/{userId}/accounts/{accountId}/transactions/{transactionId}
         * @allow Owner of the account and user path (all operations).
         * @deny Users trying to write transactions to an account they don't own.
         * @principle Enforces relational integrity between the transaction, its parent account, and the user.
         */
        match /transactions/{transactionId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.accountId == accountId;
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId && request.resource.data.accountId == resource.data.accountId;
          allow delete: if isExistingOwner(userId);

          /**
           * @description Rules for metadata about file attachments (receipts/invoices).
           * @path /users/{userId}/accounts/{accountId}/transactions/{transactionId}/attachments/{attachmentId}
           * @allow Owner of the parent transaction and user path.
           * @deny Any access that breaks the chain of ownership from user -> account -> transaction.
           * @principle Deeply nested path authorization combined with denormalized owner validation.
           */
          match /attachments/{attachmentId} {
            allow get, list: if isOwner(userId);
            allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.transactionId == transactionId;
            allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId && request.resource.data.transactionId == resource.data.transactionId;
            allow delete: if isExistingOwner(userId);
          }
        }
      }

      /**
       * @description Rules for user-defined categories for income and expenses.
       * @path /users/{userId}/transaction_categories/{transactionCategoryId}
       * @allow Owner of the parent userId path (all operations).
       * @deny Unauthenticated users or users accessing other people's categories.
       * @principle Enforces owner-only management of classification metadata.
       */
      match /transaction_categories/{transactionCategoryId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description System collection for administrative roles. Uses 'Existence over Content'.
     * @path /roles_admin/{userId}
     * @allow Any authenticated user can 'get' to check for admin status; no client-side listing.
     * @deny Client-side creation, update, or deletion of admin roles.
     * @principle Administrative privileges are managed outside the client-facing application logic.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; // Roles must be assigned via Admin SDK or Console.
    }
  }
}